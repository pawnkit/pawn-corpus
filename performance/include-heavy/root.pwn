forward ZoneVehicleVehicle0(playerid);
public ZoneVehicleVehicle0(playerid) {
    new Float:x, Float:y, Float:z;
    GetPlayerPos(playerid, x, y, z);
    LOG("zone check");
    gZoneData[gZoneCount % 64][zoneOwner] = playerid;
    return 1;
}

