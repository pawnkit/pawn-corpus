{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/pawnkit/pawn-corpus/main/schema/fixture.schema.json",
  "title": "PawnKit corpus fixture metadata",
  "description": "Metadata for one pawn-corpus fixture. See docs/fixture-metadata.md for file layouts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "category",
    "description",
    "profiles",
    "origin",
    "license",
    "kind",
    "expected"
  ],
  "properties": {
    "schemaVersion": {
      "description": "Metadata schema version.",
      "type": "string",
      "enum": ["1"]
    },
    "id": {
      "description": "Stable fixture ID derived from its repository path.",
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*(\\.[a-z0-9][a-z0-9_-]*)*$"
    },
    "category": {
      "description": "Fixture category. It must match the fixture's directory.",
      "type": "string",
      "enum": [
        "syntax-valid",
        "syntax-invalid",
        "lexer",
        "preprocessor",
        "semantics",
        "format",
        "lint",
        "lsp-edit-trace",
        "amx",
        "migrate",
        "project",
        "real-world",
        "performance"
      ]
    },
    "description": {
      "description": "Short human-readable description of what this fixture exercises.",
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "description": "PawnKit profiles for which this fixture is relevant.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["samp-037", "openmp", "legacy", "recommended", "strict", "library"]
      },
      "uniqueItems": true
    },
    "tags": {
      "description": "Extra tags used to select fixtures.",
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "kind": {
      "description": "Whether the fixture is synthetic, reduced, or imported.",
      "type": "string",
      "enum": ["synthetic", "reduced", "real-world"]
    },
    "origin": {
      "description": "Provenance of the fixture content.",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["synthetic", "reduced-from-report", "real-world"]
        },
        "sourceProject": {
          "description": "Name of the upstream project, if not synthetic.",
          "type": "string"
        },
        "sourceUrl": {
          "description": "Exact upstream URL the content was taken from, if not synthetic.",
          "type": "string",
          "format": "uri"
        },
        "sourceCommit": {
          "description": "Exact upstream commit hash or version tag the content was taken from, if not synthetic.",
          "type": "string"
        },
        "reportRef": {
          "description": "Issue/PR URL this fixture was reduced from, if kind is reduced-from-report.",
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "real-world" } }
          },
          "then": {
            "required": ["sourceProject", "sourceUrl", "sourceCommit"]
          }
        }
      ]
    },
    "license": {
      "description": "Licence and redistribution terms for this fixture.",
      "type": "object",
      "additionalProperties": false,
      "required": ["spdx", "redistribution"],
      "properties": {
        "spdx": {
          "description": "SPDX identifier or LicenseRef-pawnkit-permission for recorded written permission.",
          "type": "string",
          "minLength": 1
        },
        "redistribution": {
          "type": "string",
          "enum": ["allowed", "restricted", "forbidden"]
        },
        "attribution": {
          "description": "Required attribution text, if any.",
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "expected": {
      "description": "Expected tool behaviour for this fixture.",
      "type": "object",
      "additionalProperties": false,
      "required": ["result"],
      "properties": {
        "result": {
          "description": "'pending' means the expectation is not yet verified by the owning tool's corpus adapter.",
          "type": "string",
          "enum": ["valid", "invalid", "pending"]
        },
        "diagnosticClass": {
          "description": "Expected diagnostic class, such as lexer/unterminated-string.",
          "type": "string"
        },
        "diagnostics": {
          "description": "Zero or more expected diagnostics, for fixtures precise enough to assert structured output.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["severity", "message"],
            "properties": {
              "code": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "info", "hint"]
              },
              "message": { "type": "string" },
              "line": { "type": "integer", "minimum": 1 },
              "column": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "goldenRef": {
          "description": "Golden output path relative to the metadata file.",
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "divergences": {
      "description": "Known differences between profiles or implementations.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scope", "description"],
        "properties": {
          "scope": {
            "description": "What diverges, e.g. a profile name, a tool name, or 'pawncc-3.10.10 vs community-compiler'.",
            "type": "string"
          },
          "description": { "type": "string" }
        }
      }
    }
  }
}
